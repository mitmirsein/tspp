**/.venv-*/
venv/
ENV/

# --- Python 캐시 ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- fan-out 산출물·원천 (생성물; 커밋 제외) ---
output/
**/output/
.raw/
**/.raw/

# --- 비공개 입력 (목회자 자산: 묵상 메모·회중 프로파일·설교 샘플) ---
input/
sermon_samples/
*.local.json

