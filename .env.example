# TSPP 환경변수 샘플
# 이 파일을 `.env`로 복사한 뒤 필요한 키만 채우세요.
# `.env`는 커밋하지 않습니다.

# 한글 학술 자료 검색에 필요합니다.
KCI_OPEN_API_KEY=
NLK_DATA_GO_KR_KEY=

# 선택: Semantic Scholar 호출 한도를 안정화합니다.
SEMANTIC_SCHOLAR_API_KEY=

# 선택: Crossref polite pool용 연락 이메일입니다.
CROSSREF_MAILTO=you@example.com

# 선택: true로 두면 조건에 맞는 검색 기록을 Zotero로 자동 푸시합니다.
ZOTERO_AUTO_PUSH=false
