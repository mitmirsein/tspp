# TSPP 환경변수 샘플
# 이 파일을 `.env`로 복사한 뒤 필요한 키만 채우세요.
# `.env`는 커밋하지 않습니다.

# 한글 학술 자료 검색에 필요합니다.
KCI_OPEN_API_KEY=
NLK_DATA_GO_KR_KEY=

# 선택: Semantic Scholar 호출 한도를 안정화합니다.
SEMANTIC_SCHOLAR_API_KEY=

# 선택: Crossref polite pool용 연락 이메일입니다.
CROSSREF_MAILTO=you@example.com

# 선택: 성경 인용 게이트의 기본 번역본입니다. (기본값 KorRV = 개역한글판)
# 개역개정·새번역 등 사용자 보유본은 scripture_import.py로 변환해
# input/scripture/<코드>/에 두면 여기서 코드만 지정해 쓸 수 있습니다.
# TSPP_TRANSLATION=NKRV
